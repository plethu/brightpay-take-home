@inject IStringLocalizer<SharedResource> Localizer
@using BrightPay.TakeHome.Web.Features.Checkout.Notifications

<div class="visually-hidden" role="status" aria-live="polite" aria-atomic="true">@Message</div>

@if (!string.IsNullOrWhiteSpace(Message))
{
    @* Keyed on Generation so each visible update remounts this node and the browser replays the
       Entrance animation (slide-in / pulse / none). Leaving keeps the key stable so the existing
       node animates out instead of being torn down instantly. *@
    <div @key="Generation" class="toast @EntranceClass @(IsLeaving ? "toast-exit" : null)" aria-hidden="true">
        <span class="toast-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" focusable="false">
                <path d="m5 12 4 4L19 6" />
            </svg>
        </span>
        <span class="toast-msg">@Message</span>
        @if (OnDismiss.HasDelegate)
        {
            <button type="button" class="toast-dismiss" aria-label="@Localizer["CheckoutDismissNotification"]" @onclick="@OnDismiss">
                <span aria-hidden="true">x</span>
            </button>
        }
        else if (!string.IsNullOrWhiteSpace(DismissHref))
        {
            <a class="toast-dismiss" href="@DismissHref" aria-label="@Localizer["CheckoutDismissNotification"]">
                <span aria-hidden="true">x</span>
            </a>
        }
    </div>
}

@code {
    [Parameter]
    public string? Message { get; set; }

    [Parameter]
    public bool IsLeaving { get; set; }

    [Parameter]
    public int Generation { get; set; }

    [Parameter]
    public ToastEntrance Entrance { get; set; }

    [Parameter]
    public EventCallback OnDismiss { get; set; }

    [Parameter]
    public string? DismissHref { get; set; }

    private string? EntranceClass => Entrance switch
    {
        ToastEntrance.Enter => "toast-enter",
        ToastEntrance.Pulse => "toast-pulse",
        _ => null,
    };
}
