@page "/"
@page "/cart"
@using BrightPay.TakeHome.Core.Checkout.Basket
@using BrightPay.TakeHome.Web.Components.Checkout
@using BrightPay.TakeHome.Web.Features.Checkout
@using BrightPay.TakeHome.Web.Features.Checkout.Projection
@using BrightPay.TakeHome.Web.Features.Checkout.Routing
@using BrightPay.TakeHome.Web.Features.Checkout.State
@inject ICheckoutCatalogService CatalogService
@inject CheckoutBasketCookieStore BasketStore
@inject CheckoutViewProjector Projector
@inject IHttpContextAccessor HttpContextAccessor
@inject IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["AppName"]</PageTitle>

@if (_model is not null)
{
    <CheckoutToast Message="@Toast" />

    <section class="checkout-page" aria-labelledby="page-title">
        <div class="checkout-title">
            <h1 id="page-title">@Localizer["CartHeading"]</h1>
            <p>@Localizer["CartIntro"]</p>
        </div>

        <div class="till-e">
            <AddPad Catalog="@_model.Catalog" ErrorMessage="@ErrorMessage" />
            <section class="sale-pane" aria-labelledby="sale-hd">
                <div class="panel-head sale-head-line">
                    <h2 id="sale-hd">@Localizer["CheckoutCurrentSale"]</h2>
                    <span class="sale-count" aria-live="polite">
                        @if (!_model.Totals.IsEmpty)
                        {
                            @Localizer["CheckoutItemCount", _model.Totals.ItemCount]
                        }
                    </span>
                </div>
                <Receipt Lines="@_model.Lines" IsEmpty="@_model.Totals.IsEmpty" />
                <CheckoutTotals Totals="@_model.Totals" />
            </section>
        </div>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "sku")]
    public string? ErrorSku { get; set; }

    [SupplyParameterFromQuery(Name = "feedback")]
    public string? Feedback { get; set; }

    private CheckoutViewModel? _model;

    private CheckoutMutationErrorCode? ErrorCode =>
        Enum.TryParse(Error, ignoreCase: false, out CheckoutMutationErrorCode code) ? code : null;

    private CheckoutFeedbackCode? FeedbackCode =>
        Enum.TryParse(Feedback, ignoreCase: false, out CheckoutFeedbackCode code) ? code : null;

    private string? ErrorMessage => ErrorCode switch
    {
        CheckoutMutationErrorCode.EmptySku => Projector.ErrorMessage(BrightPay.TakeHome.Core.Checkout.Operations.CheckoutOperationError.EmptySku),
        CheckoutMutationErrorCode.InvalidQuantity => Projector.ErrorMessage(BrightPay.TakeHome.Core.Checkout.Operations.CheckoutOperationError.InvalidQuantity),
        CheckoutMutationErrorCode.UnknownSku => Projector.ErrorMessage(BrightPay.TakeHome.Core.Checkout.Operations.CheckoutOperationError.UnknownSku, ErrorSku),
        CheckoutMutationErrorCode.EmptyBasket => Projector.ErrorMessage(BrightPay.TakeHome.Core.Checkout.Operations.CheckoutOperationError.EmptyBasket),
        _ => null,
    };

    private string? Toast => FeedbackCode switch
    {
        CheckoutFeedbackCode.Charged => Localizer["CheckoutToast_Charged"].Value,
        CheckoutFeedbackCode.Cleared => Localizer["CheckoutToast_Cleared"].Value,
        _ => null,
    };

    protected override async Task OnInitializedAsync()
    {
        HttpContext? httpContext = HttpContextAccessor.HttpContext;
        BasketSnapshot basket = BasketStore.Read(httpContext);
        CheckoutCatalogSnapshot catalog = await CatalogService.LoadActiveCatalogAsync().ConfigureAwait(false);
        IReadOnlyList<CheckoutCatalogItem> catalogItems = await CatalogService.LoadCatalogItemsAsync().ConfigureAwait(false);

        _model = Projector.Project(catalog, catalogItems, basket);
    }
}
