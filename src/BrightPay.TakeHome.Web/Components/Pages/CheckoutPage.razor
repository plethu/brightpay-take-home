@page "/"
@page "/cart"
@rendermode InteractiveServer
@using BrightPay.TakeHome.Core.Checkout.Basket
@using BrightPay.TakeHome.Core.Checkout.Identifiers
@using BrightPay.TakeHome.Core.Checkout.Operations
@using BrightPay.TakeHome.Web.Components.Checkout
@using BrightPay.TakeHome.Web.Features.Checkout
@using BrightPay.TakeHome.Web.Features.Checkout.Projection
@using BrightPay.TakeHome.Web.Features.Checkout.Routing
@using BrightPay.TakeHome.Web.Features.Checkout.State
@inject ICheckoutCatalogService CatalogService
@inject ICheckoutBasketStore BasketStore
@inject CheckoutViewProjector Projector
@inject IHttpContextAccessor HttpContextAccessor
@inject PersistentComponentState ApplicationState
@inject IStringLocalizer<SharedResource> Localizer
@implements IDisposable

@if (_model is not null)
{
    <CheckoutToast Message="@_notifications.Toast" IsLeaving="@_notifications.ToastLeaving" OnDismiss="@DismissToastAsync" />

    <section class="checkout-page" data-checkout-page aria-label="@Localizer["AppName"]">
        <div class="till-e">
            <AddPad Catalog="@_model.Catalog"
                    ErrorMessage="@_notifications.ErrorMessage"
                    ErrorIsInvalid="@_notifications.ErrorIsInvalid"
                    ErrorIsLeaving="@_notifications.ErrorLeaving"
                    OnAdd="@AddAsync"
                    OnManualSkuChanged="@ClearErrorAsync" />
            <section class="sale-pane" aria-labelledby="sale-hd">
                <div class="panel-head sale-head-line">
                    <h2 id="sale-hd">@Localizer["CheckoutCurrentSale"]</h2>
                    <span class="sale-count" aria-live="polite">
                        @if (!_model.Totals.IsEmpty)
                        {
                            @Localizer["CheckoutItemCount", _model.Totals.ItemCount]
                        }
                    </span>
                </div>
                <Receipt Lines="@_model.Lines"
                         LeavingLines="@([.._leavingLines.Values])"
                         IsEmpty="@(_model.Totals.IsEmpty && _leavingLines.Count == 0)"
                         OnIncrement="@IncrementAsync"
                         OnDecrement="@DecrementAsync" />
                <CheckoutTotals Totals="@_model.Totals" OnClear="@Clear" OnCharge="@Charge" />
            </section>
        </div>
    </section>
}

@code {
    [SupplyParameterFromQuery(Name = "error")]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "sku")]
    public string? QuerySku { get; set; }

    [SupplyParameterFromQuery(Name = "feedback")]
    public string? Feedback { get; set; }

    private CheckoutViewModel? _model;
    private CheckoutCatalogSnapshot? _catalog;
    private IReadOnlyList<CheckoutCatalogItem> _catalogItems = [];
    private BasketSnapshot _basket = BasketSnapshot.Empty;
    private string _sessionId = string.Empty;
    private CheckoutNotificationController _notifications = null!;
    private PersistingComponentStateSubscription _persistingSubscription;
    private readonly Dictionary<string, CheckoutReceiptLineView> _leavingLines =
        new(StringComparer.OrdinalIgnoreCase);

    private static readonly TimeSpan LineLeaveDelay = TimeSpan.FromMilliseconds(200);

    private CheckoutMutationErrorCode? ErrorCode =>
        Enum.TryParse(Error, ignoreCase: false, out CheckoutMutationErrorCode code) ? code : null;

    private CheckoutFeedbackCode? FeedbackCode =>
        Enum.TryParse(Feedback, ignoreCase: false, out CheckoutFeedbackCode code) ? code : null;

    protected override void OnInitialized()
    {
        _notifications = new CheckoutNotificationController(
            () => InvokeAsync(StateHasChanged),
            Localizer,
            sku => _model?.Catalog.FirstOrDefault(item =>
                string.Equals(item.Sku, sku, StringComparison.OrdinalIgnoreCase))?.Name);

        _persistingSubscription = ApplicationState.RegisterOnPersisting(PersistSessionIdAsync);
    }

    protected override async Task OnInitializedAsync()
    {
        if (!ApplicationState.TryTakeFromJson<string>("sessionId", out string? persistedId))
        {
            persistedId = HttpContextAccessor.HttpContext?.Items[CheckoutSession.ItemsKey] as string;
        }

        _sessionId = persistedId ?? string.Empty;
        _basket = BasketStore.Read(_sessionId);
        _catalog = await CatalogService.LoadActiveCatalogAsync().ConfigureAwait(false);
        _catalogItems = await CatalogService.LoadCatalogItemsAsync().ConfigureAwait(false);
        Project();
        _notifications.ErrorMessage = QueryErrorMessage();
        _notifications.Toast = QueryToast();
    }

    private Task PersistSessionIdAsync()
    {
        ApplicationState.PersistAsJson("sessionId", _sessionId);
        return Task.CompletedTask;
    }

    private async Task AddAsync(CheckoutAddRequest request)
    {
        CheckoutOperationResult result = await CatalogService
            .AddAsync(_basket, request.Sku, request.Quantity)
            .ConfigureAwait(true);
        ApplyResult(result, request, CheckoutFeedbackCode.Added);
    }

    private async Task IncrementAsync(string skuText)
    {
        if (Sku.TryCreate(skuText) is not { } sku)
        {
            _notifications.ApplyFailure(Projector.ErrorMessage(CheckoutOperationError.UnknownSku, skuText));
            return;
        }

        CheckoutOperationResult result = await CatalogService
            .IncrementAsync(_basket, sku)
            .ConfigureAwait(true);
        ApplyResult(result);
    }

    private async Task DecrementAsync(string skuText)
    {
        if (Sku.TryCreate(skuText) is not { } sku)
        {
            _notifications.ApplyFailure(Projector.ErrorMessage(CheckoutOperationError.UnknownSku, skuText));
            return;
        }

        CheckoutOperationResult result = await CatalogService
            .DecrementAsync(_basket, sku)
            .ConfigureAwait(true);
        ApplyResult(result);
    }

    private void Clear()
    {
        ApplyResult(CatalogService.Clear(_basket), feedback: CheckoutFeedbackCode.Cleared);
    }

    private void Charge()
    {
        ApplyResult(CatalogService.Charge(_basket), feedback: CheckoutFeedbackCode.Charged);
    }

    private void ApplyResult(
        CheckoutOperationResult result,
        CheckoutAddRequest? addRequest = null,
        CheckoutFeedbackCode? feedback = null)
    {
        if (!result.Succeeded)
        {
            _notifications.ApplyFailure(Projector.ErrorMessage(result.Error, addRequest?.Sku));
            return;
        }

        IReadOnlyList<CheckoutReceiptLineView>? previousLines = _model?.Lines;
        _basket = result.Basket;
        BasketStore.Write(_sessionId, _basket);
        Project();

        TrackLeavingLines(previousLines);

        _ = _notifications.ClearErrorAsync();
        switch (feedback)
        {
            case CheckoutFeedbackCode.Added when addRequest is not null:
                _notifications.QueueAddedToast(addRequest.Sku, addRequest.Quantity);
                break;
            case CheckoutFeedbackCode.Charged:
                _notifications.ShowSuccessToast(Localizer["CheckoutToast_Charged"].Value);
                break;
            case CheckoutFeedbackCode.Cleared:
                _notifications.ShowSuccessToast(Localizer["CheckoutToast_Cleared"].Value);
                break;
        }
    }

    private void TrackLeavingLines(IReadOnlyList<CheckoutReceiptLineView>? previousLines)
    {
        if (previousLines is null || _model is null)
        {
            return;
        }

        HashSet<string> currentSkus = new(
            _model.Lines.Select(l => l.Sku),
            StringComparer.OrdinalIgnoreCase);

        foreach (CheckoutReceiptLineView removed in previousLines.Where(l => !currentSkus.Contains(l.Sku)))
        {
            _leavingLines[removed.Sku] = removed;
            _ = RemoveLeavingLineAsync(removed.Sku);
        }
    }

    private async Task RemoveLeavingLineAsync(string sku)
    {
        await Task.Delay(LineLeaveDelay).ConfigureAwait(true);
        _leavingLines.Remove(sku);
        await InvokeAsync(StateHasChanged).ConfigureAwait(true);
    }

    private void Project()
    {
        if (_catalog is null)
        {
            return;
        }

        _model = Projector.Project(_catalog, _catalogItems, _basket);
    }

    private string? QueryErrorMessage() => ErrorCode switch
    {
        CheckoutMutationErrorCode.EmptySku => Projector.ErrorMessage(CheckoutOperationError.EmptySku),
        CheckoutMutationErrorCode.InvalidQuantity => Projector.ErrorMessage(CheckoutOperationError.InvalidQuantity),
        CheckoutMutationErrorCode.UnknownSku => Projector.ErrorMessage(CheckoutOperationError.UnknownSku, QuerySku),
        CheckoutMutationErrorCode.EmptyBasket => Projector.ErrorMessage(CheckoutOperationError.EmptyBasket),
        _ => null,
    };

    private string? QueryToast() => FeedbackCode switch
    {
        CheckoutFeedbackCode.Added => AddedToast(QuerySku),
        CheckoutFeedbackCode.Charged => Localizer["CheckoutToast_Charged"].Value,
        CheckoutFeedbackCode.Cleared => Localizer["CheckoutToast_Cleared"].Value,
        _ => null,
    };

    private string? AddedToast(string? skuText)
    {
        if (string.IsNullOrWhiteSpace(skuText))
        {
            return null;
        }

        string? name = _model?.Catalog.FirstOrDefault(item =>
            string.Equals(item.Sku, skuText, StringComparison.OrdinalIgnoreCase))?.Name;
        return Localizer["CheckoutToast_Added", name ?? skuText].Value;
    }

    private Task ClearErrorAsync() => _notifications.ClearErrorAsync();

    private Task DismissToastAsync() => _notifications.DismissToastAsync();

    public void Dispose()
    {
        _persistingSubscription.Dispose();
        _notifications.Dispose();
    }
}
