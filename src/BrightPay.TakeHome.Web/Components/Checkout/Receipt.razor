@using BrightPay.TakeHome.Web.Features.Checkout.Projection
@inject IStringLocalizer<SharedResource> Localizer

<div class="sale-body" data-region="basket">
    @if (IsEmpty)
    {
        <div class="empty-state">
            <strong>@Localizer["CheckoutEmptyTitle"]</strong>
            <span>@Localizer["CheckoutEmptyBody"]</span>
        </div>
    }
    else
    {
        <ul class="sale-list">
            @foreach (CheckoutReceiptLineView line in Lines)
            {
                <ReceiptLine @key="@line.Sku" Line="@line"
                             LeavingOffer="@(LeavingOffers.GetValueOrDefault(line.Sku))"
                             OnIncrement="@OnIncrement" OnDecrement="@OnDecrement" />
            }
            @foreach (CheckoutReceiptLineView line in LeavingLines)
            {
                <ReceiptLine @key="@($"{line.Sku}-leaving")" Line="@line" IsLeaving="true" OnIncrement="@OnIncrement" OnDecrement="@OnDecrement" />
            }
        </ul>
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<CheckoutReceiptLineView> Lines { get; set; } = [];

    [Parameter]
    public IReadOnlyList<CheckoutReceiptLineView> LeavingLines { get; set; } = [];

    // Lines (keyed by SKU) whose offer just stopped applying, so the badge can collapse out.
    [Parameter]
    public IReadOnlyDictionary<string, CheckoutReceiptLineView> LeavingOffers { get; set; } =
        new Dictionary<string, CheckoutReceiptLineView>();

    [Parameter]
    public bool IsEmpty { get; set; }

    [Parameter]
    public EventCallback<string> OnIncrement { get; set; }

    [Parameter]
    public EventCallback<string> OnDecrement { get; set; }
}
