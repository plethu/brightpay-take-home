@* The multi-buy offer tag. Coupon icon leads the label so the offer reads as a coupon, not just
   coloured text (colour alone is not the signal — mirrors the mockup's honey tag). *@
<span class="offer-badge">
    <svg class="offer-coupon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
         stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
        <path d="M20.59 13.41 13.42 20.58a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82Z" />
        <line x1="7" y1="7" x2="7.01" y2="7" />
    </svg>
    @Label
</span>

@code {
    [Parameter]
    public required string Label { get; set; }
}
