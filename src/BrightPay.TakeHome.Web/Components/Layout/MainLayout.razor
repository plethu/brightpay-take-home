@inherits LayoutComponentBase

<div class="app-shell">
    <header class="app-header">
        <a class="brand" href="/">BrightPay take-home</a>
        <span class="header-note">.NET 10 Blazor scaffold</span>
    </header>

    <main class="app-main" id="main-content">
        @Body
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <button type="button" class="dismiss" aria-label="Dismiss error">x</button>
</div>
