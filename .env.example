# Copy this file to .env when local defaults need changing.

CONTAINER_RUNTIME=podman
TOFU="mise exec -- tofu"
DOTNET_SDK_IMAGE=mcr.microsoft.com/dotnet/sdk:10.0
DEV_CONTAINER_NAME=brightpay-takehome-web

APP_HOST_PORT=8080
ASPNETCORE_ENVIRONMENT=Development
E2E_BASE_URL=http://localhost:8080

# Docker users can switch the container runtime:
# CONTAINER_RUNTIME=docker
