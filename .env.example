# Copy this file to .env when local defaults need changing.

CONTAINER_RUNTIME=docker
TOFU="mise exec -- tofu"
DEV_CONTAINER_NAME=brightpay-takehome-web
DB_CONTAINER_NAME=brightpay-takehome-db

APP_HOST_PORT=8080
SQL_HOST_PORT=14333
SQL_SERVER_PASSWORD=BrightPay_takehome_Passw0rd!
ASPNETCORE_ENVIRONMENT=Development
E2E_BASE_URL=http://localhost:8080

# Host EF commands derive ConnectionStrings__CheckoutDatabase from
# SQL_HOST_PORT and SQL_SERVER_PASSWORD. Override it only for a custom database.
# ConnectionStrings__CheckoutDatabase="Server=127.0.0.1,14333;Database=BrightPayTakeHome;User Id=sa;Password=BrightPay_takehome_Passw0rd!;TrustServerCertificate=True"

# Podman users can switch the container runtime when podman-compose works:
# CONTAINER_RUNTIME=podman
